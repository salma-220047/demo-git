<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Digital Resume</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>
  body { scroll-behavior: smooth; }
  .hero { background: linear-gradient(135deg, #667eea, #764ba2); color:white; }
</style>
</head>

<body>

<!-- 🔥 NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
  <div class="container">
    <a class="navbar-brand">MyResume</a>

    <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="menu">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a href="#home" class="nav-link">Home</a></li>
        <li class="nav-item"><a href="#about" class="nav-link">About</a></li>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">More</a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="#projects">Projects</a></li>
            <li><a class="dropdown-item" href="#contact">Contact</a></li>
          </ul>
        </li>

      </ul>
    </div>
  </div>
</nav>

<!-- 🔥 HERO -->
<section id="home" class="hero text-center p-5" style="margin-top:60px;">
  <h1 class="display-4">Hi, I'm Your Name</h1>
  <p class="lead">Frontend Developer</p>
  <button id="toggleBtn" class="btn btn-light">Toggle Info</button>
  <p id="extraText">Welcome to my digital resume</p>
</section>

<!-- 🔥 ABOUT (GRID) -->
<section id="about" class="container mt-5">
  <div class="row align-items-center g-4">
    <div class="col-12 col-md-6">
      <img src="https://via.placeholder.com/400" class="img-fluid rounded shadow">
    </div>
    <div class="col-12 col-md-6">
      <h2>About Me</h2>
      <p>I am a passionate student learning Bootstrap and web development.</p>
      <span class="badge bg-success">Quick Learner</span>
    </div>
  </div>
</section>

<!-- 🔥 SKILLS -->
<section class="container mt-5">
  <h2>Skills</h2>

  <div class="mb-3">
    <label>HTML</label>
    <div class="progress">
      <div class="progress-bar bg-success" style="width: 90%">90%</div>
    </div>
  </div>

  <div class="mb-3">
    <label>CSS</label>
    <div class="progress">
      <div class="progress-bar bg-info" style="width: 80%">80%</div>
    </div>
  </div>
</section>

<!-- 🔥 PROJECTS (CARDS + MODAL) -->
<section id="projects" class="container mt-5">
  <h2>Projects</h2>

  <div class="row g-4">
    <div class="col-md-4">
      <div class="card shadow">
        <img src="https://via.placeholder.com/300" class="card-img-top">
        <div class="card-body">
          <h5>Project 1</h5>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#projectModal">
            View
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 🔥 MODAL -->
<div class="modal fade" id="projectModal">
  <div class="modal-dialog">
    <div class="modal-content p-3">
      <h4>Project Details</h4>
      <p>This project uses Bootstrap components.</p>
    </div>
  </div>
</div>

<!-- 🔥 EDUCATION TABLE -->
<section class="container mt-5">
  <h2>Education</h2>
  <div class="table-responsive">
    <table class="table table-striped">
      <tr><th>Year</th><th>Course</th></tr>
      <tr><td>2025</td><td>B.Tech</td></tr>
    </table>
  </div>
</section>

<!-- 🔥 CAROUSEL -->
<section class="container mt-5">
  <h2>Gallery</h2>

  <div id="carouselExample" class="carousel slide">
    <div class="carousel-inner">
      <div class="carousel-item active">
        <img src="https://via.placeholder.com/600x300" class="d-block w-100">
      </div>
      <div class="carousel-item">
        <img src="https://via.placeholder.com/600x300" class="d-block w-100">
      </div>
    </div>
  </div>
</section>

<!-- 🔥 COLLAPSE -->
<section class="container mt-5 text-center">
  <button class="btn btn-warning" data-bs-toggle="collapse" data-bs-target="#info">
    Show More
  </button>

  <div id="info" class="collapse mt-3">
    Extra hidden content here
  </div>
</section>

<!-- 🔥 CONTACT FORM -->
<section id="contact" class="container mt-5">
  <h2>Contact</h2>

  <input type="text" class="form-control mb-2" placeholder="Name">
  <input type="email" class="form-control mb-2 is-valid" placeholder="Email">
  <input type="password" class="form-control mb-2 is-invalid" placeholder="Password">

  <textarea class="form-control mb-2"></textarea>

  <select class="form-select mb-2">
    <option>Select Course</option>
  </select>

  <div>
    <input type="radio"> Male
    <input type="checkbox"> Agree
  </div>
</section>

<!-- 🔥 ALERT -->
<div class="container mt-3">
  <div class="alert alert-success">Form submitted successfully!</div>
</div>

<!-- 🔥 FOOTER -->
<footer class="bg-dark text-white text-center p-4 mt-5">
  <i class="bi bi-instagram me-3"></i>
  <i class="bi bi-github me-3"></i>
  <i class="bi bi-linkedin"></i>
</footer>

<!-- JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
$(document).ready(function(){
  $("#toggleBtn").click(function(){
    $("#extraText").toggle();
  });

  $('[data-bs-toggle="tooltip"]').tooltip();
});
</script>

</body>
</html>